---
// Side-by-side: raw Effect source <- analyzer -> structured view + stats.
// The "your code, made legible" proof on the splash hero.
// Styles live in custom.css under .ea-compare.

const code = `<span class="t-kw">export const</span> <span class="t-fn">transferWorkflow</span> = (
  <span class="t-arg">fromAccountId</span>: <span class="t-typ">string</span>,
  <span class="t-arg">toAccountId</span>: <span class="t-typ">string</span>,
  <span class="t-arg">amount</span>: <span class="t-typ">number</span>,
) =&gt;
  <span class="t-typ">Effect</span>.<span class="t-fn">gen</span>(<span class="t-kw">function*</span> () &#123;
    <span class="t-kw">const</span> accounts = <span class="t-kw">yield*</span> <span class="t-svc">AccountService</span>
    <span class="t-kw">const</span> audit    = <span class="t-kw">yield*</span> <span class="t-svc">AuditLog</span>

    <span class="t-kw">const</span> balance = <span class="t-kw">yield*</span> accounts.<span class="t-fn">getBalance</span>(fromAccountId)
    <span class="t-kw">if</span> (balance &lt; amount) &#123;
      <span class="t-kw">return yield*</span> <span class="t-typ">Effect</span>.<span class="t-fn">fail</span>(
        <span class="t-kw">new</span> <span class="t-err">InsufficientFundsError</span>(balance, amount)
      )
    &#125;

    <span class="t-kw">yield*</span> accounts.<span class="t-fn">debit</span>(fromAccountId, amount)
    <span class="t-kw">yield*</span> accounts.<span class="t-fn">credit</span>(toAccountId, amount)
    <span class="t-kw">yield*</span> audit.<span class="t-fn">record</span>(<span class="t-str">\`Transferred &#36;&#123;amount&#125;\`</span>)
  &#125;)`;
---

<section class="ea-compare">
  <div class="ea-compare__col ea-compare__col--raw">
    <div class="ea-compare__head">
      <span class="ea-compare__label">// Your code</span>
      <span class="ea-compare__meta">transfer-workflow.ts · 18 lines</span>
    </div>
    <pre class="ea-compare__code"><code set:html={code} /></pre>
    <div class="ea-compare__hints">
      <span>which services?</span>
      <span>which errors?</span>
      <span>how many paths?</span>
    </div>
  </div>

  <div class="ea-compare__bridge" aria-hidden="true">
    <div class="ea-compare__bridge-chip">
      <span class="ea-compare__bridge-dot"></span>
      <span class="ea-compare__bridge-text">analyze</span>
      <svg
        class="ea-compare__bridge-arrow"
        width="14"
        height="10"
        viewBox="0 0 14 10"
        fill="none"
      >
        <path
          d="M1 5h11m0 0L8 1m4 4L8 9"
          stroke="currentColor"
          stroke-width="1.5"
          stroke-linecap="round"
          stroke-linejoin="round"></path>
      </svg>
    </div>
  </div>

  <div class="ea-compare__col ea-compare__col--analyzed">
    <div class="ea-compare__head">
      <span class="ea-compare__label">// analyzed</span>
      <span class="ea-compare__meta is-ok">✓ 42ms · ast · no runtime</span>
    </div>

    <div class="ea-compare__diagram">
      <svg
        viewBox="0 0 280 360"
        xmlns="http://www.w3.org/2000/svg"
        preserveAspectRatio="xMidYMid meet"
      >
        <defs>
          <marker
            id="arr"
            viewBox="0 0 10 10"
            refX="9"
            refY="5"
            markerWidth="6"
            markerHeight="6"
            orient="auto-start-reverse"
          >
            <path d="M0 0 L10 5 L0 10 z" fill="#555a64"></path>
          </marker>
          <linearGradient id="okEdge" x1="0" y1="0" x2="1" y2="0">
            <stop offset="0%" stop-color="#7c6ff0"></stop>
            <stop offset="100%" stop-color="#a78bfa"></stop>
          </linearGradient>
        </defs>
        <style>
          .n-rect {
            fill: #15171c;
