---
const sampleSource = `import { Effect } from "effect";

const validateAmount = (amount: number) =>
  amount <= 0
    ? Effect.fail(new Error("amount must be positive"))
    : Effect.succeed(amount);

const reserveFunds = (amount: number) =>
  Effect.gen(function* () {
    yield* Effect.log("reserve " + amount);
    return { reservationId: "res_123", amount };
  });

const notifyLedger = (reservationId: string) =>
  Effect.log("ledger " + reservationId);

export const sendMoney = (amount: number) =>
  Effect.gen(function* () {
    const validAmount = yield* validateAmount(amount);
    const reservation = yield* reserveFunds(validAmount);

    if (validAmount > 10000) {
      yield* Effect.log("manual review required");
    }

    yield* notifyLedger(reservation.reservationId);
    return reservation;
  }).pipe(
    Effect.catchAll((error) =>
      Effect.succeed({ ok: false, reason: error.message }),
    ),
  );
`;
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <link rel="icon" type="image/svg+xml" href="/effect-analyzer/favicon.svg" />
    <title>effect-analyzer playground</title>
    <style>
      :root {
        color-scheme: light;
        --bg: #f7f4ec;
        --panel: #fffdf8;
        --border: #cbb99f;
        --text: #1f1b16;
        --muted: #6c6257;
        --accent: #b04d24;
        --accent-strong: #8c3116;
      }

      body {
        margin: 0;
        font-family: "Inter Variable", sans-serif;
        background:
          radial-gradient(circle at top left, rgba(176, 77, 36, 0.14), transparent 26rem),
          linear-gradient(180deg, #f9f5ed 0%, #f1eadf 100%);
        color: var(--text);
      }

      .topbar {
        display: flex;
        align-items: center;
        gap: 0.75rem;
        padding: 0.6rem 1.25rem;
        border-bottom: 1px solid var(--border);
        background: rgba(255, 253, 248, 0.85);
        backdrop-filter: blur(8px);
        font-size: 0.85rem;
      }

      .topbar a {
        color: var(--accent);
        text-decoration: none;
        font-weight: 500;
      }

      .topbar a:hover {
        text-decoration: underline;
      }

      .topbar .sep {
        color: var(--border);
      }

      .topbar .current {
        color: var(--text);
        font-weight: 600;
      }

      main {
        max-width: 1100px;
        margin: 0 auto;
        padding: 2rem 1.25rem 4rem;
      }

      h1 {
        font-size: clamp(2rem, 5vw, 3.75rem);
        line-height: 0.95;
        margin: 0 0 0.75rem;
      }

      p {
        color: var(--muted);
        max-width: 55rem;
      }

      .grid {
        display: grid;
        grid-template-columns: 1.1fr 0.9fr;
        gap: 1rem;
        margin-top: 2rem;
      }

      .panel {
        background: rgba(255, 253, 248, 0.92);
        border: 1px solid var(--border);
        border-radius: 18px;
        padding: 1rem;
        box-shadow: 0 18px 50px rgba(87, 61, 34, 0.08);
      }

      .controls {
        display: flex;
        gap: 0.75rem;
        flex-wrap: wrap;
        align-items: center;
        margin-bottom: 0.9rem;
      }

      .eyebrow {
        display: flex;
        justify-content: space-between;
        align-items: center;
        gap: 0.75rem;
        margin-bottom: 0.8rem;
      }

      .eyebrow-title {
        font-size: 0.78rem;
        font-weight: 700;
        letter-spacing: 0.12em;
        text-transform: uppercase;
        color: var(--muted);
      }

      .pill {
        display: inline-flex;
        align-items: center;
        border: 1px solid var(--border);
        border-radius: 999px;
        padding: 0.3rem 0.65rem;
        background: rgba(176, 77, 36, 0.08);
        color: var(--accent-strong);
        font-size: 0.78rem;
        font-weight: 600;
      }

      button, select {
        border-radius: 999px;
        border: 1px solid var(--border);
        padding: 0.72rem 1rem;
        background: var(--panel);
        color: var(--text);
        font: inherit;
      }

      button {
        background: var(--accent);
        color: white;
        border-color: var(--accent);
        cursor: pointer;
      }

      button:hover {
        background: var(--accent-strong);
      }

      textarea, pre {
        width: 100%;
        min-height: 34rem;
        box-sizing: border-box;
        border: 1px solid var(--border);
        border-radius: 14px;
        padding: 1rem;
        background: #fffefb;
        color: var(--text);
        font: 14px/1.5 "JetBrains Mono", monospace;
      }

      pre {
        overflow: auto;
        margin: 0;
        white-space: pre-wrap;
        word-break: break-word;
      }

      .output-stack {
        display: grid;
        gap: 0.85rem;
      }

      .diagram-shell {
        min-height: 34rem;
        box-sizing: border-box;
        border: 1px solid var(--border);
        border-radius: 14px;
        padding: 1rem;
        background:
          linear-gradient(180deg, rgba(255, 255, 255, 0.92), rgba(248, 243, 233, 0.92)),
          radial-gradient(circle at top left, rgba(176, 77, 36, 0.08), transparent 20rem);
        overflow: auto;
      }

      .diagram-shell[hidden] {
        display: none;
      }

      .html-shell {
        width: 100%;
        min-height: 34rem;
        border: 1px solid var(--border);
        border-radius: 14px;
        background: #0f1117;
      }

      .html-shell[hidden] {
        display: none;
      }

      .diagram-shell svg {
        display: block;
        width: 100%;
        height: auto;
      }

      .hint {
        margin: 0;
        font-size: 0.9rem;
        color: var(--muted);
      }

      .status {
        margin: 0 0 0.8rem;
        min-height: 1.5rem;
        font-size: 0.95rem;
        color: var(--muted);
      }

      @media (max-width: 900px) {
        .grid {
          grid-template-columns: 1fr;
        }

        textarea, pre, .diagram-shell {
          min-height: 24rem;
        }

        .html-shell {
          min-height: 24rem;
        }

        .diagram-shell > * {
          min-width: 32rem;
        }
      }
    </style>
  </head>
  <body>
    <nav class="topbar">
      <a href="/effect-analyzer/">effect-analyzer</a>
      <span class="sep">/</span>
      <a href="/effect-analyzer/reference/interactive-html/">Reference</a>
      <span class="sep">/</span>
      <span class="current">Playground</span>
    </nav>
    <main>
      <h1>Browser Playground</h1>
      <p>
        This is a direct browser trial of the new source-only analyzer path.
        It injects <code>ts-morph</code> at runtime and turns pasted Effect code
        into a live interactive analysis viewer in the browser.
      </p>
      <p>
        The page starts by building the seeded sample automatically, then lets
        you replace it with your own code or switch to lighter output formats.
      </p>

      <div class="grid">
        <section class="panel">
          <div class="eyebrow">
            <div class="eyebrow-title">Sample Input</div>
            <div class="pill">Seeded Effect program</div>
          </div>
          <div class="controls">
            <button id="analyze-button">Analyze</button>
            <select id="format-select" aria-label="Output format">
              <option value="html-viewer" selected>Interactive HTML Viewer</option>
              <option value="mermaid-railway">Mermaid Railway</option>
              <option value="summary">Summary</option>
              <option value="explain">Explain</option>
              <option value="json">JSON</option>
            </select>
          </div>
          <textarea id="source-input" spellcheck="false">{sampleSource}</textarea>
        </section>

        <section class="panel">
          <div class="eyebrow">
            <div class="eyebrow-title">Analyzer Output</div>
            <div id="sample-badge" class="pill">Loading viewer</div>
            <button id="open-fullpage" title="Open in new tab" hidden style="
              background: var(--panel); color: var(--muted); border-color: var(--border);
              padding: 0.3rem 0.6rem; font-size: 0.75rem; cursor: pointer;
            ">&#x2197; Full page</button>
          </div>
          <div id="status" class="status">Preparing seeded interactive viewer...</div>
          <div class="output-stack">
            <iframe
              id="output-html"
              class="html-shell"
              title="Interactive playground output"
              hidden
            ></iframe>
            <div id="output-diagram" class="diagram-shell">
              <div>No diagram yet.</div>
            </div>
            <pre id="output-text" hidden>No output yet.</pre>
            <p class="hint">
              Start with the interactive viewer, then switch to Mermaid, Explain,
              or JSON if you want the lighter representations.
            </p>
          </div>
        </section>
      </div>
    </main>

    <script>
      import { setupPlayground } from '../scripts/playground';

      setupPlayground();
    </script>
  </body>
</html>
