---
const sampleSource = `import { Effect } from "effect";

const validateAmount = (amount: number) =>
  amount <= 0
    ? Effect.fail(new Error("amount must be positive"))
    : Effect.succeed(amount);

const reserveFunds = (amount: number) =>
  Effect.gen(function* () {
    yield* Effect.log("reserve " + amount);
    return { reservationId: "res_123", amount };
  });

const notifyLedger = (reservationId: string) =>
  Effect.log("ledger " + reservationId);

export const sendMoney = (amount: number) =>
  Effect.gen(function* () {
    const validAmount = yield* validateAmount(amount);
    const reservation = yield* reserveFunds(validAmount);

    if (validAmount > 10000) {
      yield* Effect.log("manual review required");
    }

    yield* notifyLedger(reservation.reservationId);
    return reservation;
  }).pipe(
    Effect.catch((error) =>
      Effect.succeed({ ok: false, reason: error.message }),
    ),
  );
`;
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <link rel="icon" type="image/svg+xml" href="/effect-analyzer/favicon.svg" />
    <title>effect-analyzer playground</title>
    <style>
      :root {
        color-scheme: dark;
        --bg:         #0a0b0f;
        --bg-surface: #15171c;
        --bg-elevated:#1c1e24;
        --panel:      #15171c;
        --border:     rgba(255, 255, 255, 0.06);
        --border-strong: rgba(255, 255, 255, 0.12);
        --text:   #e6e8ed;
        --muted:  #8b919c;
        --dim:    #555a64;
        --primary:      #7c6ff0;
        --primary-soft: #a78bfa;
        --accent: #c8ff3a;
        --signal: #4dd4ff;

        --font-sans: 'Inter Variable', 'Inter', -apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif;
        --font-mono: 'JetBrains Mono', ui-monospace, 'SF Mono', Menlo, monospace;

        --radius:    4px;
        --radius-lg: 8px;
      }

      *, *::before, *::after { box-sizing: border-box; }

      body {
        margin: 0;
        font-family: var(--font-sans);
        color: var(--text);
        background:
          radial-gradient(ellipse 60% 50% at 50% 0%, rgba(124, 111, 240, 0.18), transparent 70%),
          radial-gradient(rgba(255, 255, 255, 0.045) 1px, transparent 1px) 0 0 / 24px 24px,
          var(--bg);
        background-attachment: fixed;
        -webkit-font-smoothing: antialiased;
        -moz-osx-font-smoothing: grayscale;
      }

      ::selection { background: var(--primary); color: #fff; }

      .topbar {
        display: flex;
        align-items: center;
        gap: 0.6rem;
        padding: 0.7rem 1.25rem;
        border-bottom: 1px solid var(--border);
        background: rgba(10, 11, 15, 0.72);
        backdrop-filter: saturate(180%) blur(14px);
        -webkit-backdrop-filter: saturate(180%) blur(14px);
        font-family: var(--font-mono);
        font-size: 0.78rem;
        letter-spacing: 0.02em;
        position: sticky;
        top: 0;
        z-index: 10;
      }

      .topbar a {
        color: var(--muted);
        text-decoration: none;
        font-weight: 500;
        transition: color 150ms ease;
      }
      .topbar a:hover { color: var(--text); }

      .topbar .sep { color: var(--dim); }

      .topbar .current {
        color: var(--text);
        font-weight: 600;
      }

      .topbar .version {
        margin-left: auto;
        padding: 2px 6px;
        border: 1px solid var(--border-strong);
        border-radius: 3px;
        color: var(--muted);
        font-size: 0.62rem;
        letter-spacing: 0.06em;
        text-transform: uppercase;
        line-height: 1;
      }

      main {
        max-width: 1200px;
        margin: 0 auto;
        padding: 3rem 1.25rem 4rem;
      }

      .hero-eyebrow {
        display: inline-flex;
        align-items: center;
        gap: 0.55rem;
        font-family: var(--font-mono);
        font-size: 0.7rem;
        letter-spacing: 0.14em;
        text-transform: uppercase;
        color: var(--muted);
        margin-bottom: 1rem;
      }
      .hero-eyebrow::before {
        content: '';
        width: 0.5rem;
        height: 0.5rem;
        border-radius: 50%;
        background: var(--accent);
        box-shadow: 0 0 12px var(--accent);
        animation: ea-pulse 2.4s cubic-bezier(0.4, 0, 0.6, 1) infinite;
      }

      h1 {
        font-size: clamp(2rem, 1.4rem + 3vw, 3.25rem);
        font-weight: 750;
        letter-spacing: -0.035em;
        line-height: 1;
        margin: 0 0 1rem;
        background: linear-gradient(180deg, #f7f8fa 0%, #b8bcc6 100%);
        -webkit-background-clip: text;
        background-clip: text;
        -webkit-text-fill-color: transparent;
      }

      main > p {
        color: var(--muted);
        max-width: 60ch;
        line-height: 1.6;
        margin: 0 0 0.75rem;
      }

      main > p code {
        font-family: var(--font-mono);
        font-size: 0.85em;
        padding: 0.12em 0.4em;
        border-radius: 3px;
        background: var(--bg-elevated);
        border: 1px solid var(--border);
        color: var(--primary-soft);
      }

      .grid {
        display: grid;
        grid-template-columns: 1.1fr 0.9fr;
        gap: 1rem;
        margin-top: 2.5rem;
      }

      .panel {
        background: var(--panel);
        border: 1px solid var(--border);
        border-radius: var(--radius-lg);
        padding: 1.1rem;
        position: relative;
        overflow: hidden;
      }
      .panel::before {
        content: '';
        position: absolute;
        inset: 0;
        background: linear-gradient(135deg, color-mix(in oklab, var(--primary) 8%, transparent) 0%, transparent 40%);
        pointer-events: none;
        opacity: 0.4;
      }
      .panel > * { position: relative; }

      .controls {
        display: flex;
        gap: 0.5rem;
        flex-wrap: wrap;
        align-items: center;
        margin-bottom: 0.9rem;
      }

      .eyebrow {
        display: flex;
        justify-content: space-between;
        align-items: center;
        gap: 0.75rem;
        margin-bottom: 0.85rem;
      }

      .eyebrow-title {
        font-family: var(--font-mono);
        font-size: 0.7rem;
        font-weight: 600;
        letter-spacing: 0.14em;
        text-transform: uppercase;
        color: var(--muted);
      }
      .eyebrow-title::before {
        content: '// ';
        color: var(--accent);
      }

      .pill {
        display: inline-flex;
        align-items: center;
        gap: 0.45rem;
        border: 1px solid var(--border-strong);
        border-radius: 999px;
        padding: 0.3rem 0.65rem 0.3rem 0.55rem;
        background: var(--bg-surface);
        color: var(--text);
        font-family: var(--font-mono);
        font-size: 0.68rem;
        font-weight: 500;
        letter-spacing: 0.04em;
        text-transform: uppercase;
      }
      .pill::before {
        content: '';
        width: 0.4rem;
        height: 0.4rem;
        border-radius: 50%;
        background: var(--signal);
        box-shadow: 0 0 8px var(--signal);
      }

      button, select {
        border-radius: var(--radius);
        border: 1px solid var(--border-strong);
        padding: 0.6rem 0.95rem;
        background: var(--bg-elevated);
        color: var(--text);
        font: 500 0.85rem/1 var(--font-sans);
        cursor: pointer;
        transition: border-color 150ms ease, background 150ms ease, transform 150ms ease, box-shadow 200ms ease;
      }

      select {
        font-family: var(--font-mono);
        font-size: 0.78rem;
        appearance: none;
        background-image:
          linear-gradient(45deg, transparent 50%, var(--muted) 50%),
          linear-gradient(135deg, var(--muted) 50%, transparent 50%);
        background-position:
          calc(100% - 14px) 50%,
          calc(100% - 9px) 50%;
        background-size: 5px 5px;
        background-repeat: no-repeat;
        padding-right: 2rem;
      }
      select:hover, select:focus {
        border-color: var(--primary);
        outline: none;
      }

      button#analyze-button {
        background: linear-gradient(135deg, var(--primary) 0%, var(--primary-soft) 100%);
        color: #fff;
        border: 1px solid color-mix(in oklab, var(--primary) 70%, transparent);
        box-shadow:
          0 1px 0 rgba(255, 255, 255, 0.18) inset,
          0 6px 18px -8px color-mix(in oklab, var(--primary) 80%, transparent);
      }
      button#analyze-button:hover {
        transform: translateY(-1px);
        box-shadow:
          0 1px 0 rgba(255, 255, 255, 0.22) inset,
          0 10px 22px -8px color-mix(in oklab, var(--primary) 90%, transparent);
      }

      button#open-fullpage {
        background: var(--bg-surface) !important;
        color: var(--muted) !important;
        border-color: var(--border-strong) !important;
        font-family: var(--font-mono);
        font-size: 0.68rem !important;
        text-transform: uppercase;
        letter-spacing: 0.06em;
        padding: 0.3rem 0.6rem !important;
      }
      button#open-fullpage:hover {
        color: var(--text) !important;
        border-color: var(--primary) !important;
      }

      textarea, pre {
        width: 100%;
        min-height: 34rem;
        box-sizing: border-box;
        border: 1px solid var(--border);
        border-radius: var(--radius-lg);
        padding: 1rem;
        background: #0d0e13;
        color: var(--text);
        font: 13.5px/1.6 var(--font-mono);
      }
      textarea:focus {
        outline: none;
        border-color: var(--primary);
        box-shadow: 0 0 0 3px color-mix(in oklab, var(--primary) 18%, transparent);
      }

      pre {
        overflow: auto;
        margin: 0;
        white-space: pre-wrap;
        word-break: break-word;
        color: var(--muted);
      }

      .output-stack {
        display: grid;
        gap: 0.85rem;
      }

      .diagram-shell {
        min-height: 34rem;
        box-sizing: border-box;
        border: 1px solid var(--border);
        border-radius: var(--radius-lg);
        padding: 1rem;
        background:
          radial-gradient(circle at top left, rgba(124, 111, 240, 0.06), transparent 20rem),
          var(--bg-surface);
        overflow: auto;
        color: var(--muted);
      }

      .diagram-shell[hidden] { display: none; }

      .html-shell {
        width: 100%;
        min-height: 34rem;
        border: 1px solid var(--border);
        border-radius: var(--radius-lg);
        background: #0a0b0f;
      }
      .html-shell[hidden] { display: none; }

      .diagram-shell svg {
        display: block;
        width: 100%;
        height: auto;
      }

      .hint {
        margin: 0;
        font-family: var(--font-mono);
        font-size: 0.72rem;
        letter-spacing: 0.02em;
        color: var(--dim);
      }
      .hint::before {
        content: '// ';
        color: var(--accent);
      }

      .status {
        margin: 0 0 0.8rem;
        min-height: 1.5rem;
        font-family: var(--font-mono);
        font-size: 0.78rem;
        color: var(--muted);
      }

      @keyframes ea-pulse {
        0%, 100% { opacity: 1; transform: scale(1); }
        50%      { opacity: 0.55; transform: scale(0.85); }
      }

      @media (prefers-reduced-motion: reduce) {
        *, *::before, *::after {
          animation-duration: 0.01ms !important;
          animation-iteration-count: 1 !important;
          transition-duration: 0.01ms !important;
        }
      }

      @media (max-width: 900px) {
        .grid {
          grid-template-columns: 1fr;
        }

        textarea, pre, .diagram-shell {
          min-height: 24rem;
        }

        .html-shell {
          min-height: 24rem;
        }

        .diagram-shell > * {
          min-width: 32rem;
        }
      }
    </style>
  </head>
  <body>
    <nav class="topbar">
      <a href="/effect-analyzer/">effect-analyzer</a>
      <span class="sep">/</span>
      <a href="/effect-analyzer/reference/html-viewer/">Reference</a>
      <span class="sep">/</span>
      <span class="current">Playground</span>
      <span class="version">v0.0.8</span>
    </nav>
    <main>
      <span class="hero-eyebrow">// browser · ts-morph · interactive analysis</span>
      <h1>Browser Playground</h1>
      <p>
        A direct browser trial of the source-only analyzer path. Injects
        <code>ts-morph</code> at runtime and turns pasted Effect code into
        a live interactive analysis viewer — no server, no install.
      </p>
      <p>
        The page builds the seeded sample automatically, then lets you
        replace it with your own code or switch to lighter output formats.
      </p>

      <div class="grid">
        <section class="panel">
          <div class="eyebrow">
            <div class="eyebrow-title">Sample Input</div>
            <div class="pill">Seeded Effect program</div>
          </div>
          <div class="controls">
            <button id="analyze-button">Analyze</button>
            <select id="format-select" aria-label="Output format">
              <option value="html-viewer" selected>Interactive HTML Viewer</option>
              <option value="mermaid-railway">Mermaid Railway</option>
              <option value="summary">Summary</option>
              <option value="explain">Explain</option>
              <option value="json">JSON</option>
            </select>
          </div>
          <textarea id="source-input" spellcheck="false">{sampleSource}</textarea>
        </section>

        <section class="panel">
          <div class="eyebrow">
            <div class="eyebrow-title">Analyzer Output</div>
            <div id="sample-badge" class="pill">Loading viewer</div>
            <button id="open-fullpage" title="Open in new tab" hidden style="
              background: var(--panel); color: var(--muted); border-color: var(--border);
              padding: 0.3rem 0.6rem; font-size: 0.75rem; cursor: pointer;
            ">&#x2197; Full page</button>
          </div>
          <div id="status" class="status">Preparing seeded interactive viewer...</div>
          <div class="output-stack">
            <iframe
              id="output-html"
              class="html-shell"
              title="Interactive playground output"
              hidden
            ></iframe>
            <div id="output-diagram" class="diagram-shell">
              <div>No diagram yet.</div>
            </div>
            <pre id="output-text" hidden>No output yet.</pre>
            <p class="hint">
              Start with the interactive viewer, then switch to Mermaid, Explain,
              or JSON if you want the lighter representations.
            </p>
          </div>
        </section>
      </div>
    </main>

    <script>
      import { setupPlayground } from '../scripts/playground';

      setupPlayground();
    </script>
  </body>
</html>
