{
  "name": "effect-analyzer",
  "version": "0.3.4",
  "type": "module",
  "description": "Static analysis for Effect-TS code. Analyze Effect code to extract structure, calculate complexity, and generate visualizations.",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "sideEffects": [
    "./src/register-node-ts-morph.ts"
  ],
  "bin": {
    "effect-analyze": "./dist/cli.js"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    },
    "./analysis": {
      "types": "./dist/analysis.d.ts",
      "import": "./dist/analysis.js",
      "require": "./dist/analysis.cjs"
    },
    "./diagram": {
      "types": "./dist/diagram.d.ts",
      "import": "./dist/diagram.js",
      "require": "./dist/diagram.cjs"
    },
    "./rules": {
      "types": "./dist/rules.d.ts",
      "import": "./dist/rules.js",
      "require": "./dist/rules.cjs"
    },
    "./migration": {
      "types": "./dist/migration.d.ts",
      "import": "./dist/migration.js",
      "require": "./dist/migration.cjs"
    },
    "./browser": {
      "types": "./dist/browser.d.ts",
      "import": "./dist/browser.js",
      "require": "./dist/browser.cjs"
    },
    "./effect-workflow": {
      "types": "./dist/effect-workflow.d.ts",
      "import": "./dist/effect-workflow.js",
      "require": "./dist/effect-workflow.cjs"
    }
  },
  "files": [
    "dist",
    "scripts",
    "README.md",
    "state-machine-conventions.md"
  ],
  "scripts": {
    "build": "tsup",
    "lsp": "node dist/lsp/server.js",
    "type-check": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest watch",
    "lint": "eslint src",
    "lint:fix": "eslint src --fix",
    "clean": "rm -rf dist",
    "quality": "pnpm type-check && pnpm test && pnpm lint",
    "effect:fetch": "tsx scripts/fetch-effect-repo.ts"
  },
  "keywords": [
    "effect",
    "effect-ts",
    "static-analysis",
    "ts-morph",
    "typescript",
    "visualization",
    "mermaid",
    "functional-programming"
  ],
  "author": "Jag Reehal <jag@jagreehal.com>",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/jagreehal/effect-analyzer.git",
    "directory": "packages/effect-analyzer"
  },
  "bugs": {
    "url": "https://github.com/jagreehal/effect-analyzer/issues"
  },
  "homepage": "https://github.com/jagreehal/effect-analyzer/tree/main/packages/effect-analyzer#readme",
  "peerDependencies": {
    "effect": "^4.0.0-beta.99"
  },
  "peerDependenciesMeta": {
    "effect": {
      "optional": false
    }
  },
  "dependencies": {
    "effect": "^4.0.0-beta.99",
    "ts-morph": "^28.0.0"
  },
  "optionalDependencies": {
    "vscode-languageserver": "^9.0.1",
    "vscode-languageserver-textdocument": "^1.0.13"
  },
  "devDependencies": {
    "@effect/eslint-plugin": "^0.3.2",
    "@eslint/js": "^10.0.1",
    "@total-typescript/ts-reset": "^0.6.1",
    "@types/node": "^25.9.2",
    "eslint": "^10.6.0",
    "ts-morph": "^28.0.0",
    "tsup": "^8.5.1",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.64.0",
    "vitest": "^4.1.8"
  }
}
